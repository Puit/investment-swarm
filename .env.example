# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=tu_token_de_botfather_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# OPENAI (opcional, si usas GPT)
OPENAI_API_KEY=sk-...

# OLLAMA (si usas local Mistral)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# ── TRADING 212 ────────────────────────────────────────────────
# Cómo obtenerlas: Settings → API (beta) → Create key
#   · ID de clave API  = identificador visible en el panel T212 (no autentica)
#   · Clave secreta    = el token real (solo visible al crear la key, guárdala bien)
# Crea una key distinta para cada tipo de cuenta (demo y live son cuentas separadas).

# Paper trading — cuenta DEMO de Trading 212
T212_API_KEY_ID_PAPER_TRADING=id_visible_en_el_panel_t212_demo
T212_API_SECRET_PAPER_TRADING=clave_secreta_de_tu_cuenta_demo

# Live trading — cuenta REAL de Trading 212 (cuando la tengas)
T212_API_KEY_ID_LIVE_TRADING=id_visible_en_el_panel_t212_live
T212_API_SECRET_LIVE_TRADING=clave_secreta_de_tu_cuenta_real

# PAPER TRADING - COMISIONES
PAPER_TRADING_COMMISSION_PERCENT=0.1
PAPER_TRADING_INITIAL_CAPITAL=5000.0

# DESARROLLO
DEBUG=False
LOG_LEVEL=INFO
